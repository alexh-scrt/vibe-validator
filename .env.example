# =============================================================================
# Vibe Validator — Environment Variable Template
# =============================================================================
# Copy this file to .env and fill in the values before running the application.
#
#   cp .env.example .env
#
# NEVER commit your .env file to version control.
# =============================================================================

# --- OpenAI -------------------------------------------------------------------
# Your OpenAI API key. Obtain one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-replace-me

# OpenAI model to use for viability analysis.
# Recommended: gpt-4o  |  Budget option: gpt-3.5-turbo
OPENAI_MODEL=gpt-4o

# Maximum tokens the LLM may return per request.
OPENAI_MAX_TOKENS=2048

# --- Application --------------------------------------------------------------
# Host and port for the Uvicorn server.
APP_HOST=0.0.0.0
APP_PORT=8000

# Set to "development" for auto-reload or "production" for optimised serving.
APP_ENV=development

# Secret key used for any future session/cookie signing (generate a random value).
APP_SECRET_KEY=change-me-to-a-long-random-string
